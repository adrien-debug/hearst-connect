{
  "name": "hearst-connect",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "lsof -ti:8100 | xargs kill -9 2>/dev/null; sleep 1; next dev --port 8100 --webpack",
    "build": "next build --webpack",
    "start": "next start --port 8100",
    "lint": "tsc -p . --noEmit && node scripts/check-design-system.mjs",
    "lint:design": "node scripts/check-design-system.mjs",
    "test": "vitest run",
    "contracts:build": "cd contracts && forge build && cd .. && node scripts/sync-abi.mjs",
    "contracts:test": "cd contracts && forge test -vvv",
    "contracts:coverage": "cd contracts && forge coverage --report lcov",
    "contracts:fmt": "cd contracts && forge fmt",
    "contracts:deploy:sepolia": "cd contracts && forge script script/Deploy.s.sol:DeployScript --rpc-url base_sepolia --broadcast --verify -vvvv && cd .. && node scripts/sync-addresses.mjs 84532",
    "contracts:sync": "node scripts/sync-abi.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@tailwindcss/webpack": "^4.2.2",
    "@tanstack/react-query": "^5.99.2",
    "better-sqlite3": "^12.9.0",
    "chart.js": "^4.5.1",
    "jose": "^6.2.2",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "siwe": "^3.0.0",
    "viem": "^2.48.4",
    "wagmi": "^3.6.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "null-loader": "^4.0.1",
    "postcss": "^8",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
