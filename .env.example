# ── Application ────────────────────────────────────────────────────────────────

# Authentication (REQUIRED in production)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long

# Admin access (comma-separated Ethereum addresses)
ADMIN_ADDRESSES=0x1234567890123456789012345678901234567890

# Web3 (optional - WalletConnect project ID for wallet modal branding)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXXX

# ── Smart contracts (Foundry, used by `npm run contracts:*`) ───────────────────
# These are NEVER read by the Next.js runtime; they live here so the Foundry CLI
# picks them up via dotenv. Vercel must NOT receive DEPLOYER_PRIVATE_KEY.

BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASESCAN_API_KEY=

# Deployer EOA (clean wallet, ETH-funded). Used only by `forge script`.
DEPLOYER_PRIVATE_KEY=

# Vault deploy params (consumed by contracts/script/Deploy.s.sol)
ASSET_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e   # Circle USDC on Base Sepolia
ADMIN_ADDRESS=                                              # Safe multisig address
TREASURY_ADDRESS=                                           # defaults to ADMIN_ADDRESS
POCKET_COUNT=3
TARGET_BPS=3600
LOCK_PERIOD=604800        # 7 days for testnet QA; 93312000 (1080d) for mainnet
MIN_DEPOSIT=1000000000    # 1k USDC for testnet; 500_000e6 mainnet
MGMT_FEE_BPS=150
PERF_FEE_BPS=1500
BASE_APR_BPS=1200
MAX_RECOVERY_DAYS=730
MAX_TVL=0                 # 0 = uncapped on testnet; cap on mainnet day 1

# ── Frontend chain config ──────────────────────────────────────────────────────
NEXT_PUBLIC_DEFAULT_CHAIN_ID=84532
NEXT_PUBLIC_USDC_ADDRESS_SEPOLIA=0x036CbD53842c5426634e7929541eC2318f3dCF7e
NEXT_PUBLIC_VAULT_ADDRESS_PRIME_SEPOLIA=
